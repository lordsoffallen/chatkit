{
  "name": "@lordsoffallen/chatkit-cli",
  "version": "0.1.0",
  "description": "Chatkit source installer for chat UI and artifact blocks.",
  "type": "module",
  "scripts": {
    "prepare:templates": "node ./scripts/prepare-templates.mjs",
    "prepack": "npm run prepare:templates"
  },
  "files": [
    "bin",
    "templates",
    "src",
    "README.md"
  ],
  "bin": {
    "chatkit": "bin/chatkit.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "chatkit",
    "cli",
    "chatbot",
    "shadcn",
    "ai"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lordsoffallen/chatkit.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/lordsoffallen/chatkit#readme",
  "bugs": {
    "url": "https://github.com/lordsoffallen/chatkit/issues"
  }
}
